generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Domain {
  id          String   @id @default(cuid())
  name        String
  status      String   @default("pending")
  nameservers String[]
  zoneId      String?
  userId      String
  createdAt   DateTime @default(now())
  forwardingUrl String?

  @@unique([userId, name])
}
model Mailbox {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  username  String
  domainId  String
  email     String
  platform  String   @default("google")
  status    String   @default("pending")
  userId    String
  createdAt DateTime @default(now())

  @@unique([email])
}
model UserRole {
  id        String   @id @default(cuid())
  userId    String   @unique
  email     String
  role      String   @default("client") // client | team | admin
  createdAt DateTime @default(now())
}
model ArchivedClient {
  id           String   @id @default(cuid())
  userId       String
  email        String
  domainCount  Int      @default(0)
  mailboxCount Int      @default(0)
  note         String?
  deletedAt    DateTime @default(now())
}
model EmailStat {
  id        String   @id @default(cuid())
  mailboxId String
  userId    String
  date      DateTime
  sent      Int      @default(0)
  received  Int      @default(0)
  replies   Int      @default(0)
  bounces   Int      @default(0)

  @@unique([mailboxId, date])
}